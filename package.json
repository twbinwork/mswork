{
  "name": "sea-sim",
  "version": "1.0.0",
  "description": "Local SEA entity simulation with Leaflet and Canvas",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:win": "pkg . --targets node16-win-x64 --output build/sea-sim-win.exe",
    "build:mac": "pkg . --targets node16-macos-x64 --output build/sea-sim-mac",
    "build:linux": "pkg . --targets node16-linux-x64 --output build/sea-sim-linux",
    "build:all": "npm run build:win && npm run build:mac && npm run build:linux"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "leaflet": "^1.9.4",
    "leaflet-control-layers-inline": "^0.0.7",
    "leaflet-providers": "^3.0.0"
  },
  "pkg": {
    "scripts": [
      "server.js"
    ],
    "assets": [
      "public/**/*",
      "node_modules/leaflet/dist/**/*"
    ],
    "targets": [
      "node16-win-x64",
      "node16-macos-x64",
      "node16-linux-x64"
    ],
    "outputPath": "build"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
